# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local dev:  postgresql://todo:todopass@localhost:5432/tododb
# Neon:       postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Railway:    postgresql://postgres:pass@containers-us-west-xxx.railway.app:6543/railway
DATABASE_URL="postgresql://todo:todopass@localhost:5432/tododb"

# ── App ─────────────────────────────────────────────────────────────────────────
NODE_ENV="development"

# CORS allowed origin for the API (leave * for development)
CORS_ORIGIN="*"

# ── Docker Compose ─────────────────────────────────────────────────────────────
POSTGRES_USER="todo"
POSTGRES_PASSWORD="todopass"
POSTGRES_DB="tododb"
